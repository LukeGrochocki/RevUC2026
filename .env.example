# Copy to `.env` and fill in. Do not commit `.env`.
FEATHERLESS_API_KEY=
GEMINI_API_KEY=
SCREENSHOTONE_ACCESS_KEY=
# Optional: GOOGLE_API_KEY=  # alternative to GEMINI_API_KEY
# Optional: GEMINI_MODEL=gemini-2.5-flash  # override if your key requires another model id
# Optional: SCREENSHOTONE_VIEWPORT_WIDTH=1280 SCREENSHOTONE_VIEWPORT_HEIGHT=720
# Optional: SCREENSHOTONE_TIMEOUT=90  SCREENSHOTONE_RETRIES=4  SCREENSHOTONE_FULL_PAGE=true
# Optional: FEATHERLESS_TIMEOUT=300  FEATHERLESS_RETRIES=5  FEATHERLESS_MAX_TOKENS=4096  FEATHERLESS_GEMINI_CONTEXT_CHARS=20000  FEATHERLESS_STREAM=1
